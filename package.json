{
  "name": "tuduk-tuduk-rpg",
  "version": "2.1.2",
  "description": "투닥투닥 RPG - 모험단 성장 시뮬레이션",
  "type": "module",
  "scripts": {
    "slice-ui": "node scripts/slice-ui-atlas.mjs",
    "slice:dungeon": "node scripts/slice-dungeon-bg.mjs",
    "install:backgrounds": "node scripts/install-rpg-backgrounds.mjs",
    "install:backgrounds:2026": "node scripts/install-stage-backgrounds-2026.mjs",
    "upscale:backgrounds": "node scripts/upscale-backgrounds.mjs",
    "setup:pipoya": "node scripts/setup-pipoya-a.mjs",
    "install:monsters": "node scripts/install-uploaded-monsters.mjs",
    "install:soldier": "node scripts/install-soldier-frames.mjs",
    "install:tiny-rpg": "node scripts/install-tiny-rpg.mjs",
    "install:rmmz-se": "node scripts/install-rmmz-se.mjs",
    "install:rmmz-bgm": "node scripts/install-rmmz-bgm.mjs",
    "dev": "vite --host",
    "dev:watch": "vite --host",
    "verify:assets": "node scripts/verify-assets.mjs",
    "extract:skill-icons": "node scripts/extract-skill-icons.mjs",
    "build": "npm run verify:assets && tsc && vite build",
    "balance:audit": "npx tsx scripts/balance-audit.mjs",
    "test:e2e": "playwright test",
    "balance:dps": "npx tsx scripts/compare-floor10-dps.mjs",
    "preview": "vite preview",
    "serve:remote": "npm run build && vite preview --host 0.0.0.0 --port 5200",
    "android:init": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android && node scripts/patch-android-admob.mjs",
    "android:open": "npx cap open android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleRelease",
    "android:apk:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:icons": "npx @capacitor/assets generate --iconBackgroundColor \"#000000\" --splashBackgroundColor \"#000000\"",
    "ios:init": "npx cap add ios",
    "ios:sync": "npm run build && npx cap sync ios && node scripts/patch-ios-admob.mjs",
    "ios:open": "npx cap open ios",
    "ios:pods": "cd ios/App && pod install",
    "ios:icons": "npx @capacitor/assets generate --ios --assetPath resources --iconBackgroundColor \"#000000\" --splashBackgroundColor \"#000000\" --logoSplashScale 0.55",
    "ios:prepare": "npm run ios:icons && npm run ios:sync",
    "ios:build": "bash scripts/build-ios-mac.sh",
    "ios:build:appstore": "bash scripts/build-ios-appstore.sh",
    "release:apk": "npm run android:apk && node scripts/copy-release-apk.mjs",
    "release:prepare": "npm run release:apk && npm run ios:sync",
    "iphone:pwa": "node scripts/serve-iphone-pwa.mjs",
    "share:prepare": "node scripts/prepare-friend-share.mjs",
    "netlify:prepare": "node scripts/prepare-netlify-upload.mjs",
    "pwa:icons": "npx @capacitor/assets generate --pwa --assetPath resources --iconBackgroundColor \"#000000\" --splashBackgroundColor \"#000000\""
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.2.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "@iconify-json/game-icons": "^1.2.4",
    "@iconify/utils": "^3.1.3",
    "@playwright/test": "^1.61.0",
    "typescript": "^5.4.5",
    "vite": "^5.4.11"
  }
}
