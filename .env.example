# AdMob — 프로덕션 빌드용 (.env.production 에 복사 후 실제 ID 입력)
# 개발(npm run dev)은 자동으로 Google 테스트 ID 사용
VITE_ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
VITE_ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
VITE_ADMOB_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
VITE_ADMOB_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# TestFlight·내부 테스트에서 테스트 광고 강제 (선택)
# VITE_ADMOB_TESTING=true
